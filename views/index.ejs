        <a href="/login" class="btn btn-lg">Entrar</a>
        <a href="/register" class="btn btn-lg btn-outline">Criar conta</a>
      </div>
    </div>
  </div>

  <footer class="landing-foot">
    <p>© <%= new Date().getFullYear() %> FitTrack — feito para quem treina.</p>
  </footer>
