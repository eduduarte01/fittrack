<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include("../partials/head", { title: workout.title }) %>
</head>
<body>
  <%- include("../partials/navbar") %>
  
  <main class="container" style="margin-top: 40px; max-width: 800px;">
    <div class="card">
      <p style="color: var(--green-primary); font-weight: 800; text-transform: uppercase; font-size: 0.8rem; margin-bottom: 10px;">
        <%= workout.category ? workout.category.name : 'Sem categoria' %>
      </p>
      <h1 style="margin-bottom: 20px;"><%= workout.title %></h1>
      
      <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 12px; background: #000; margin-bottom: 30px; border: 1px solid #374151;">
        <iframe 
          style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
          src="<%= workout.video_url %>" 
          frameborder="0" 
          allowfullscreen>
        </iframe>
      </div>

      <div style="background: var(--black-input); padding: 20px; border-radius: 8px; margin-bottom: 30px;">
        <h3 style="margin-bottom: 10px; font-size: 1rem; color: var(--gray-text);">Descrição do Treino</h3>
        <p style="white-space: pre-wrap;"><%= workout.description %></p>
      </div>

      <a href="/workouts" class="btn btn-outline">&larr; Voltar para a lista</a>
    </div>
  </main>

  <%- include("../partials/footer") %>
</body>
</html>
