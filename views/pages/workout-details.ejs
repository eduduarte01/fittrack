<main class="container">
  <div class="card workout-detail">
    <p class="meta"><%= workout.category ? workout.category.name : 'Sem categoria' %></p>
    <h1 style="margin-bottom: 20px;"><%= workout.title %></h1>

    <div class="video-wrapper">
      <iframe src="<%= workout.video_url %>" allowfullscreen></iframe>
    </div>

    <div class="description-block">
      <h3>Descrição do Treino</h3>
      <p><%= workout.description %></p>
    </div>

    <a href="/workouts" class="btn btn-outline">&larr; Voltar para a lista</a>
  </div>
</main>
