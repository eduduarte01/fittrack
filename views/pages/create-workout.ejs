<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include('../partials/head', { title: 'Criar Treino | FitTrack' }) %>
</head>
<body>
  <%- include('../partials/navbar', { active: 'criar' }) %>
  
  <div class="container" style="margin-top: 40px; max-width: 600px;">
    <div class="card">
      <h1 style="margin-bottom: 10px;">Criar Novo Treino</h1>
      <p style="color: var(--gray-text); margin-bottom: 25px;">Preencha os detalhes abaixo para salvar seu treino.</p>
      
      <%- include('../partials/alerts') %>

      <form action="/workouts/create" method="POST">
        <div class="form-group">
          <label for="title">Título do Treino</label>
          <input type="text" id="title" name="title" placeholder="Ex: Hipertrofia de Peitoral" required />
        </div>

        <div class="form-group">
          <label for="category_id">Categoria</label>
          <select id="category_id" name="category_id" required>
            <option value="">Selecione uma categoria...</option>
            <% categories.forEach(function(cat) { %>
              <option value="<%= cat.id %>"><%= cat.name %></option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label for="description">Descrição / Exercícios</label>
          <textarea id="description" name="description" rows="5" placeholder="Liste os exercícios, séries e repetições..."></textarea>
        </div>

        <div class="form-group">
          <label for="video_url">Link do Vídeo (YouTube Embed)</label>
          <input type="text" id="video_url" name="video_url" placeholder="https://www.youtube.com/embed/..." required />
          <small style="color: var(--gray-text ); font-size: 0.75rem;">Dica: Use o link de 'Incorporar' do YouTube.</small>
        </div>

        <div style="display: flex; gap: 10px; margin-top: 30px;">
          <a href="/feed" class="btn btn-outline" style="flex: 1;">Cancelar</a>
          <button type="submit" class="btn" style="flex: 2;">Salvar Treino</button>
        </div>
      </form>
    </div>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>
